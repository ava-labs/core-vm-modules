{
  "name": "@avalabs/evm-module",
  "version": "0.0.23",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts",
  "type": "module",
  "scripts": {
    "build": "tsup",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "gen:contracts": "typechain --target=ethers-v6 --out-dir src/contracts/openzeppelin ./node_modules/@openzeppelin/contracts/build/contracts/ERC20.json ./node_modules/@openzeppelin/contracts/build/contracts/ERC721.json ./node_modules/@openzeppelin/contracts/build/contracts/ERC1155.json",
    "postinstall": "pnpm run gen:contracts"
  },
  "dependencies": {
    "@avalabs/vm-module-types": "0.0.23",
    "@avalabs/coingecko-sdk": "v2.8.0-alpha.195",
    "@avalabs/utils-sdk": "2.8.0-alpha.195",
    "@avalabs/etherscan-sdk": "v2.8.0-alpha.195",
    "@avalabs/glacier-sdk": "v2.8.0-alpha.195",
    "@avalabs/wallets-sdk": "v2.8.0-alpha.195",
    "@blockaid/client": "0.11.0",
    "bn.js": "5.2.1",
    "lodash.startcase": "4.4.0",
    "@metamask/rpc-errors": "6.3.0",
    "zod": "3.23.8",
    "@zodios/core": "10.9.6",
    "@avalabs/types": "2.8.0-alpha.193"
  },
  "devDependencies": {
    "typechain": "8.3.1",
    "@typechain/ethers-v6": "0.5.0",
    "@openzeppelin/contracts": "4.9.3",
    "@types/bn.js": "5.1.5",
    "@internal/tsup-config": "workspace:*",
    "@types/jest": "29.5.7",
    "@types/lodash.startcase": "4.4.9",
    "eslint-config-custom": "workspace:*",
    "@internal/utils": "workspace:*",
    "jest": "29.7.0",
    "ts-jest": "29.1.1",
    "tsup": "7.2.0",
    "ethers": "6.8.1"
  },
  "peerDependencies": {
    "ethers": "^6.8.1"
  }
}
