{
  "name": "@avalabs/evm-module",
  "version": "0.7.1",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "typings": "dist/index.d.ts",
  "type": "module",
  "files": [
    "dist",
    "manifest.json"
  ],
  "license": "Limited Ecosystem License",
  "scripts": {
    "build": "tsup",
    "lint": "eslint \"src/**/*.ts\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "gen:contracts": "typechain --target=ethers-v6 --out-dir src/contracts/openzeppelin ./node_modules/@openzeppelin/contracts/build/contracts/ERC20.json ./node_modules/@openzeppelin/contracts/build/contracts/ERC721.json ./node_modules/@openzeppelin/contracts/build/contracts/ERC1155.json",
    "postinstall": "pnpm run gen:contracts"
  },
  "dependencies": {
    "@avalabs/vm-module-types": "workspace:*",
    "@avalabs/core-coingecko-sdk": "3.1.0-alpha.5",
    "@avalabs/core-etherscan-sdk": "3.1.0-alpha.5",
    "@avalabs/core-utils-sdk": "3.1.0-alpha.5",
    "@avalabs/core-wallets-sdk": "3.1.0-alpha.5",
    "@avalabs/glacier-sdk": "3.1.0-alpha.5",
    "@avalabs/types": "3.1.0-alpha.5",
    "@blockaid/client": "0.11.0",
    "@metamask/rpc-errors": "6.3.0",
    "bn.js": "5.2.1",
    "lodash.startcase": "4.4.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@internal/tsup-config": "workspace:*",
    "@internal/utils": "workspace:*",
    "@openzeppelin/contracts": "4.9.3",
    "@typechain/ethers-v6": "0.5.0",
    "@types/bn.js": "5.1.5",
    "@types/jest": "29.5.7",
    "@types/lodash.startcase": "4.4.9",
    "eslint-config-custom": "workspace:*",
    "ethers": "6.8.1",
    "jest": "29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "ts-jest": "29.1.1",
    "tsup": "7.2.0",
    "typechain": "8.3.1"
  },
  "peerDependencies": {
    "ethers": "^6.8.1"
  },
  "volta": {
    "node": "20.11.0",
    "yarn": "1.22.19"
  }
}
