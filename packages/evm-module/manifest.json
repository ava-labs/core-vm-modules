          "registry": "https://registry.npmjs.org"
        }
      }
    },
    "provider": {
      "checksum": "",
      "location": {
        "npm": {
          "filePath": "dist/provider.js",
          "packageName": "@avalabs/evm-module",
          "registry": "https://registry.npmjs.org"
        }
      }
